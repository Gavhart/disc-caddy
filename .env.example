# Disc Caddy — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Public site URL (required for native App Store / Play builds — auth email links)
VITE_APP_URL=https://thedisccaddy.com

# Stripe (web checkout only — optional for mobile shell)
VITE_STRIPE_PRICE_ID_MONTHLY=price_...
VITE_STRIPE_PRICE_ID_ANNUAL=price_...

# Web push (optional)
# VITE_VAPID_PUBLIC_KEY=...
